{
  "name": "@ifecodes/backend-template",
  "version": "1.3.0",
  "description": "Production-ready Express + TypeScript/JavaScript backend generator with optional features and microservice support",
  "bin": {
    "ifecodes-template": "bin/cli.js"
  },
  "type": "module",
  "files": [
    "bin",
    "template"
  ],
  "scripts": {
    "test": "vitest",
    "lint": "eslint . --ext .js,.ts --ignore-pattern 'template/**'",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ALADETAN-IFE/backend-template.git"
  },
  "bugs": {
    "url": "https://github.com/ALADETAN-IFE/backend-template/issues"
  },
  "homepage": "https://backend-template-generator.vercel.app",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "template",
    "boilerplate",
    "typescript",
    "javascript",
    "backend",
    "express",
    "microservice",
    "monolith",
    "nodejs",
    "generator",
    "scaffold",
    "docker",
    "pm2",
    "jwt",
    "authentication",
    "colored-cli"
  ],
  "license": "MIT",
  "author": "Aladetan Fortune Ifeloju (IfeCodes) <fortuneifealadetan01@gmail.com>",
  "dependencies": {
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "vitest": "^1.5.2",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^2.8.8",
    "eslint-config-prettier": "^10.1.8",
    "@types/node": "^20.1.0"
  }
}
